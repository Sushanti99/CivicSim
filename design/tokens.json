{
  "name": "CivicSim Design System",
  "version": "1.0.0",
  "description": "Design tokens for CivicSim website, slides, and brand materials",

  "colors": {
    "brand": {
      "cyan":   { "light": "#1d4ed8", "dark": "#00d4ff", "hex_light": "#1D4ED8", "hex_dark": "#00D4FF" },
      "violet": { "light": "#2563eb", "dark": "#a855f7", "hex_light": "#2563EB", "hex_dark": "#A855F7" },
      "green":  { "value": "#10b981", "hex": "#10B981" },
      "amber":  { "value": "#f59e0b", "hex": "#F59E0B" },
      "red":    { "value": "#ef4444", "hex": "#EF4444" }
    },
    "background": {
      "page_light":    "#f6f9ff",
      "page_alt_light":"#eef5ff",
      "page_dark":     "#070a14",
      "page_alt_dark": "#0a0e1c"
    },
    "surface": {
      "card_light":    "#ffffff",
      "card_dark":     "#0f1421",
      "card_2_light":  "#eaf2ff",
      "card_2_dark":   "#151b2d"
    },
    "text": {
      "primary_light": "#0b1f4d",
      "primary_dark":  "#e8eaf0",
      "dim_light":     "#486381",
      "dim_dark":      "#a0a8bd",
      "faint_light":   "#7b8ea8",
      "faint_dark":    "#6b7390"
    },
    "ui": {
      "policy_blue":   "#2563EB",
      "policy_violet": "#7C3AED",
      "policy_green":  "#059669",
      "trust_banner_from": "#1e3a8a",
      "trust_banner_to":   "#2563eb"
    }
  },

  "typography": {
    "sans": "Inter, ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto",
    "mono": "JetBrains Mono, SF Mono, Menlo, ui-monospace, monospace",
    "scale": {
      "hero_title":     { "size": "clamp(2.5rem, 6.5vw, 5rem)", "weight": 700, "tracking": "-0.035em", "line_height": 1.05 },
      "section_title":  { "size": "clamp(1.75rem, 3.5vw, 2.5rem)", "weight": 700, "tracking": "-0.025em", "line_height": 1.15 },
      "study_h3":       { "size": "clamp(1.5rem, 3vw, 2rem)", "weight": 700, "tracking": "-0.022em", "line_height": 1.2 },
      "body":           { "size": "1rem",   "weight": 400, "line_height": 1.7 },
      "body_small":     { "size": "0.95rem","weight": 400, "line_height": 1.6 },
      "label_mono":     { "size": "0.72rem","weight": 600, "tracking": "0.12em" },
      "stat_number":    { "size": "3.5rem", "weight": 600, "tracking": "-0.03em" }
    }
  },

  "spacing": {
    "section_y":    "6rem",
    "hero_y":       "8rem 2rem 5rem",
    "container_x":  "2rem",
    "max_width":    "1180px",
    "card_pad":     "1.75rem",
    "card_radius":  "14px",
    "card_radius_lg":"18px"
  },

  "borders": {
    "radius": {
      "sm": "6px",
      "md": "10px",
      "lg": "14px",
      "xl": "18px",
      "pill": "999px"
    },
    "color_light": "rgba(37, 99, 235, 0.14)",
    "color_hi_light": "rgba(37, 99, 235, 0.26)"
  },

  "shadows": {
    "card":      "0 8px 32px rgba(0,0,0,0.24)",
    "card_glow": "0 16px 52px rgba(37, 99, 235, 0.12)",
    "trust_banner": "0 20px 60px rgba(37, 99, 235, 0.35)"
  },

  "gradients": {
    "hero_bg": "radial-gradient(circle at 14% 12%, rgba(37,99,235,0.12), transparent 30rem), radial-gradient(circle at 86% 8%, rgba(14,165,233,0.10), transparent 34rem)",
    "cta_button": "linear-gradient(135deg, #1d4ed8 0%, #2ee0ff 100%)",
    "stat_number": "linear-gradient(135deg, #1d4ed8, #2563eb)",
    "trust_banner": "linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%)",
    "proof_banner": "radial-gradient(circle at 0% 0%, rgba(29,78,216,0.14), transparent 50%), linear-gradient(135deg, #f6f9ff, #eef5ff)"
  },

  "presentation": {
    "slide_bg_light":  "#f6f9ff",
    "slide_bg_dark":   "#070a14",
    "slide_accent":    "#2563eb",
    "slide_accent_2":  "#a855f7",
    "heading_color":   "#0b1f4d",
    "subheading_color":"#486381",
    "stat_color":      "#1d4ed8",
    "note": "For slides: use Inter (or Helvetica Neue as fallback) at 700 for headings. Use JetBrains Mono for numbers, code, and mono labels."
  }
}
