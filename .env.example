# --- LLM provider (one of openai | anthropic | mock) ---
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o-mini

# Set whichever provider you chose above
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Path (relative to backend/) to the bundled ATP priors parquet
ATP_PRIORS_PATH=../data/atp_priors/policy_priors.parquet

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
